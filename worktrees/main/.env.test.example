# Test environment configuration for E2E tests
# Copy to .env.test and fill with your test Zotero credentials

# Option 1: Use test Zotero Web API account
TEST_ZOTERO_LOCAL=false
TEST_ZOTERO_LIBRARY_ID=your_test_library_id
TEST_ZOTERO_API_KEY=your_test_api_key
TEST_ZOTERO_LIBRARY_TYPE=user

# Option 2: Use local Zotero SQLite database
# TEST_ZOTERO_LOCAL=true
# TEST_ZOTERO_DB_PATH=/path/to/test/zotero.sqlite

# Test data keys (create these in your test library)
TEST_COLLECTION_KEY=ABCD1234  # Collection with sample items
TEST_ITEM_WITH_PDF=ITEM1234   # Item that has PDF attachment
TEST_ITEM_NO_PDF=ITEM5678     # Item without attachments